{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "950px",
      "wideSize": "1280px"
    },
    "dimensions": {
      "aspectRatio": true,
      "minHeight": true
    },
    "spacing": {
      "blockGap": true,
      "customSpacingSize": true,
      "padding": true,
      "margin": true,
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vh",
        "vw"
      ],
      "spacingSizes": [
        {
          "name": "XS",
          "slug": "xs",
          "size": "0.5rem"
        },
        {
          "name": "S",
          "slug": "s",
          "size": "1rem"
        },
        {
          "name": "M",
          "slug": "m",
          "size": "1.5rem"
        },
        {
          "name": "L",
          "slug": "l",
          "size": "2.5rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "4rem"
        },
        {
          "name": "2XL",
          "slug": "2-xl",
          "size": "6rem"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "position": {
      "sticky": true
    },
    "typography": {
      "customFontSize": true,
      "lineHeight": true,
      "fluid": true
    },
    "color": {
      "background": true,
      "button": true,
      "caption": true,
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultGradients": true,
      "heading": true,
      "link": true,
      "text": true,
      "palette": [
        {
          "name": "Primary Blue",
          "slug": "primary-blue",
          "color": "#2563eb"
        },
        {
          "name": "Deep Blue",
          "slug": "deep-blue",
          "color": "#1e40af"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#7c3aed"
        },
        {
          "name": "Gold",
          "slug": "gold",
          "color": "#f59e0b"
        },
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#111827"
        },
        {
          "name": "Soft Gray",
          "slug": "soft-gray",
          "color": "#f3f4f6"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        }
      ]
    }
  }
}
